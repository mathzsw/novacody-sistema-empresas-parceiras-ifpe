<h1>Cadastro de Empresa</h1>
<p>Diferente</p>
<form action="/empresa/admin" method="POST">


    Nome:
    <input type="text" name="nome"><br><br>

    CNPJ:
    <input type="text" name="cnpj"><br><br>

    Email:
    <input type="text" name="email"><br><br>

    Telefone:
    <input type="text" name="telefone"><br><br>

    Contato:
    <input type="text" name="contato"><br><br>

    Endereço:
    <input type="text" name="endereco"><br><br>

    Tipo de parceria:
    <input type="text" name="tipo_parceria"><br><br>

    Website:
    <input type="text" name="website"><br><br>

    Quantidade de vagas:
    <input type="number" name="quantidade_vagas"><br><br>

    Descrição:
    <textarea name="descricao_vagas"></textarea><br><br>

    Aceita estagiário:
    <input type="checkbox" name="aceita_estagiario"><br><br>

    Observações:
    <textarea name="observacoes"></textarea><br><br>

    <button type="submit">Cadastrar</button>

</form>
