<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Cadastro Empresa</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="form-container">

    <a href="/" class="voltar">
        ← Voltar
    </a>

    <div class="form-box">

        <h2>Cadastro de Empresa Parceira</h2>

        <p>
            Preencha os dados da empresa para parceria com o IFPE
        </p>

        <form action="/empresa/admin" method="POST">

            <label>Nome da Empresa *</label>
            <input type="text" name="nome">

            <label>CNPJ *</label>
            <input type="text" name="cnpj">

            <label>E-mail *</label>
            <input type="text" name="email">

            <label>Telefone *</label>
            <input type="text" name="telefone">

            <label>Pessoa do Contato *</label>
            <input type="text" name="contato">

            <label>Endereço *</label>
            <input type="text" name="endereco">

            <h3>Informações de Parceria</h3>

            <label>Tipo de Parceria *</label>
            <input type="text" name="tipo_parceria">

            <label>Website</label>
            <input type="text" name="website">

            <label>Vagas Disponíveis</label>
            <input type="number" name="quantidade_vagas">

            <div class="checkbox-area">
                <input type="checkbox" name="aceita_estagiario">
                <span>Aceita Estagiários</span>
            </div>

            <label>Observações</label>
            <textarea name="observacoes"></textarea>

            <div class="botoes">
                <a href="/" class="btn-cancelar">
                    Cancelar
                </a>
                <button type="submit" class="btn-cadastro">
                    Cadastrar Empresa
                </button>
            </div>

        </form>

    </div>

</div>

</body>
</html>